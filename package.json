{
  "name": "@cardgamesplay/klondike",
  "version": "0.1.0",
  "description": "Browser-based Klondike Solitaire game built with TypeScript and vanilla DOM. Features drag-and-drop, keyboard navigation, card animations, sound effects, a music player, and i18n support for 16 languages. Play free at https://www.cardgamesplay.com/",
  "license": "MIT",
  "author": "Card Games Play",
  "homepage": "https://www.cardgamesplay.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bgbigbrother/klondike.git"
  },
  "bugs": {
    "url": "https://github.com/bgbigbrother/klondike/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://www.cardgamesplay.com/"
  },
  "keywords": [
    "klondike",
    "solitaire",
    "card-game",
    "patience",
    "browser-game",
    "typescript",
    "vanilla-js",
    "drag-and-drop",
    "keyboard-accessible",
    "i18n",
    "web-audio",
    "free-online-game",
    "canvas-game",
    "html5-game"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./game/*": {
      "import": "./dist/game/*.js",
      "types": "./dist/game/*.d.ts"
    },
    "./ui/*": {
      "import": "./dist/ui/*.js",
      "types": "./dist/ui/*.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n/index.js",
      "types": "./dist/i18n/index.d.ts"
    },
    "./i18n/*": {
      "import": "./dist/i18n/*.js",
      "types": "./dist/i18n/*.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./game/*": {
        "import": "./dist/game/*.js",
        "types": "./dist/game/*.d.ts"
      },
      "./ui/*": {
        "import": "./dist/ui/*.js",
        "types": "./dist/ui/*.d.ts"
      },
      "./i18n": {
        "import": "./dist/i18n/index.js",
        "types": "./dist/i18n/index.d.ts"
      },
      "./i18n/*": {
        "import": "./dist/i18n/*.js",
        "types": "./dist/i18n/*.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "prepublishOnly": "npm run build",
    "test": "vitest --run"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@rse/soundlp": "^1.1.1",
    "cardsJS": "^1.0.0"
  },
  "devDependencies": {
    "@vitest/ui": "^1.0.0",
    "fast-check": "^3.0.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
