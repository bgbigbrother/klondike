{
  "name": "@cardgames/klondike",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./game/*": {
      "import": "./dist/game/*.js",
      "types": "./dist/game/*.d.ts"
    },
    "./ui/*": {
      "import": "./dist/ui/*.js",
      "types": "./dist/ui/*.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n/index.js",
      "types": "./dist/i18n/index.d.ts"
    },
    "./i18n/*": {
      "import": "./dist/i18n/*.js",
      "types": "./dist/i18n/*.d.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./game/*": {
        "import": "./dist/game/*.js",
        "types": "./dist/game/*.d.ts"
      },
      "./ui/*": {
        "import": "./dist/ui/*.js",
        "types": "./dist/ui/*.d.ts"
      },
      "./i18n": {
        "import": "./dist/i18n/index.js",
        "types": "./dist/i18n/index.d.ts"
      },
      "./i18n/*": {
        "import": "./dist/i18n/*.js",
        "types": "./dist/i18n/*.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "prepublishOnly": "npm run build",
    "test": "vitest --run"
  },
  "dependencies": {
    "@rse/soundlp": "^1.1.1",
    "cardsJS": "^1.0.0"
  },
  "devDependencies": {
    "@vitest/ui": "^1.0.0",
    "fast-check": "^3.0.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
